<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>Brief</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>

    <!-- Microphone access for standalone Watch recording -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Brief uses the Watch microphone to record voice notes without requiring your iPhone.</string>

    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Brief transcribes your voice on Apple Watch to send notes to your iPhone.</string>

    <!-- WatchKit -->
    <key>WKApplication</key>
    <true/>
    <key>WKExtensionDelegateClassName</key>
    <string>$(PRODUCT_MODULE_NAME).ExtensionDelegate</string>

    <!-- Companion app bundle ID -->
    <key>WKCompanionAppBundleIdentifier</key>
    <string>com.brief.app</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
</dict>
</plist>
